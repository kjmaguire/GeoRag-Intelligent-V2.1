# =============================================================================
# GeoRAG Intelligence V1.0 — Environment Variables
# =============================================================================
#
# Copy this file to .env and fill in all required values before running
# docker compose. Variables marked REQUIRED have no default and must be set.
# Variables marked RECOMMENDED should be changed from the default for anything
# beyond a first-run smoke test.
#
#   cp .env.example .env
#
# Generate secrets with:
#   openssl rand -base64 32     (for passwords and keys)
#   php artisan key:generate --show    (for APP_KEY inside the container)
# =============================================================================


# =============================================================================
# APPLICATION SETTINGS
# Applies to: laravel-octane, laravel-horizon, laravel-reverb
# =============================================================================

APP_NAME="GeoRAG Intelligence"

# Environment: local | staging | production
APP_ENV=local

# REQUIRED — Laravel application encryption key.
# Generate with: php artisan key:generate --show
# Must be exactly 32 characters, base64-encoded: base64:...
APP_KEY=base64:CHANGE_ME_GENERATE_WITH_PHP_ARTISAN_KEY_GENERATE

# Enable/disable debug mode. Must be false in production.
# Module 9 Chunk 9.7 — flipped default to false. Local-dev environments that
# want stack traces should override in their personal .env (NOT .env.example).
APP_DEBUG=false

# Module 9 Chunk 9.7 — reverse-proxy IP allowlist for X-Forwarded-* trust.
# Wildcard '*' is dev-friendly. Production should set the explicit CIDR of
# your nginx/Traefik front-end (e.g. '10.0.0.0/8' or '172.16.0.0/12').
TRUSTED_PROXIES=*

# Module 9 Chunk 9.6 — session cookie Secure flag. Defaults true outside
# local env via config/session.php logic. Override only if you know why.
# SESSION_SECURE_COOKIE=true

# Multi-tenant RBAC enforcement (FastAPI config.py).
# MULTI_TENANT_ENFORCEMENT_ENABLED=false requires SINGLE_TENANT_MODE=true — FastAPI
# will refuse to start if both are false (prevents accidental unenforced deployments).
# Dev default: enforcement off + single-tenant escape hatch on (no JWT workspace claims needed).
# Production: flip to MULTI_TENANT_ENFORCEMENT_ENABLED=true, SINGLE_TENANT_MODE=false.
MULTI_TENANT_ENFORCEMENT_ENABLED=false
SINGLE_TENANT_MODE=true

# Public URL of the application (used for redirects, email links, asset URLs)
APP_URL=http://localhost

# Octane server port (host side)
# Host port for Laravel Octane. Default 80 often conflicts — use 8888 if so.
APP_PORT=8888

# Log verbosity: debug | info | warning | error | critical
LOG_LEVEL=debug

# Octane worker process settings — tune to your CPU core count
# Workstation (8-core): workers=4, task-workers=6 leaves headroom for other work
OCTANE_WORKERS=4
OCTANE_TASK_WORKERS=6
OCTANE_MAX_REQUESTS=500


# =============================================================================
# POSTGRESQL / POSTGIS
# Applies to: postgresql, pgbouncer, laravel-*, fastapi, dagster-*
#
# Applications connect to PgBouncer (port 6432), NOT PostgreSQL directly (5432).
# PostgreSQL port 5432 is NOT exposed to the host.
# =============================================================================

# REQUIRED — database name, user, password
POSTGRES_DB=georag
POSTGRES_USER=georag
POSTGRES_PASSWORD=georag_dev_password

# PgBouncer host port (exposed to host for direct inspection with psql)
PGBOUNCER_PORT=6432

# PostgreSQL performance tuning — Threadripper Pro 5955WX (16C/32T) +
# 64 GB RAM + RTX A4500 20 GB + 1.8 TB NVMe, single-purpose dev workstation.
# Hardware-refresh 2026-05-08: previous defaults (4 GB shared_buffers,
# 12 GB effective_cache_size, 8-core compose) were sized for an 8-core /
# shared-workstation era and left ~50 GB RAM unused. The dedicated box
# can reclaim it. See ops/baselines/capacity-planning.md.

# shared_buffers: ~12% of RAM. 8 GB is the working-set ceiling for our
# vector-aware query plans (HNSW prefetch + GIST index pages). Pushing
# higher hits diminishing returns since most reads land in OS page
# cache via effective_cache_size.
POSTGRES_SHARED_BUFFERS=8GB

# effective_cache_size: 50% of RAM. Single-tenant dev means the OS won't
# steal page cache from us. Was 12 GB; 32 GB lets the planner pick
# index-scan plans on warm tables far more aggressively.
POSTGRES_EFFECTIVE_CACHE_SIZE=32GB

# work_mem: per sort/hash operation. 192 MB for dev (was 128 MB). With
# 16 cores running max_parallel_workers=12, worst-case concurrent
# allocation is ~2.3 GB — well under the OS budget.
POSTGRES_WORK_MEM=192MB

# maintenance_work_mem: VACUUM / CREATE INDEX / CLUSTER. NVMe + 32-thread
# Threadripper handles 2 GB cleanly; index builds on the silver schema
# (pgTAP suite) drop ~40% with this bump.
POSTGRES_MAINTENANCE_WORK_MEM=2GB

# random_page_cost: 1.1 for NVMe (default 4.0 is for spinning disks — critical override)
POSTGRES_RANDOM_PAGE_COST=1.1

# effective_io_concurrency: NVMe + Threadripper PCIe x16 lanes can sustain
# 256+ concurrent IO requests. Was 200 in the 8-core era; raise so
# bitmap heap scans on the geochem JSONB columns prefetch aggressively.
POSTGRES_EFFECTIVE_IO_CONCURRENCY=256

# max_worker_processes / max_parallel_workers / per_gather: tuned for the
# 16-core Threadripper. Was 8/8/4 in the 8-core compose; 24/12/6 lets
# Postgres parallelise the long-running silver-schema rollups + Dagster
# ingestion sweeps without starving the serving path's small queries.
POSTGRES_MAX_WORKER_PROCESSES=24
POSTGRES_MAX_PARALLEL_WORKERS=12
POSTGRES_MAX_PARALLEL_WORKERS_PER_GATHER=6
POSTGRES_MAX_PARALLEL_MAINTENANCE_WORKERS=6

# Max concurrent connections to PostgreSQL.
# PgBouncer multiplexes these, so applications can open far more client connections.
POSTGRES_MAX_CONNECTIONS=200


# =============================================================================
# REDIS 8
# Applies to: laravel-*, fastapi
#
# Used for: application cache, session storage, Horizon job queues.
# maxmemory 1GB with allkeys-lru on the dedicated dev workstation
# (was 512 MB pre-2026-05-08 hardware refresh — 64 GB RAM total leaves
# ample headroom; 1 GB doubles the retrieval-cache hit rate per
# §05c without any pressure on Postgres / vLLM / Dagster).
# =============================================================================

REDIS_HOST=redis
# Host port for Redis. Default 6379 often conflicts with host Redis — use 6380 if so.
REDIS_PORT=6380

# Optional password — leave empty for no-auth (dev only, NOT for production)
REDIS_PASSWORD=georag_redis_dev

# Memory limit for the cache Redis instance
REDIS_MAXMEMORY=1gb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# AOF (append-only file) persistence. "yes" gives ≤1s durability for Horizon
# queue jobs and sessions. Set to "no" for a pure cache instance.
REDIS_APPENDONLY=yes
# fsync policy: everysec = sync once per second (~5% perf cost, ≤1s data loss)
REDIS_APPENDFSYNC=everysec

# ── Prod 3-instance topology (staging/prod compose profiles only) ───────────
# Leave these unset for dev — Laravel falls back to REDIS_HOST/REDIS_PASSWORD.
# When set, they route cache / queue / sessions to dedicated Redis instances
# with role-appropriate eviction policies (allkeys-lru / noeviction /
# volatile-lru). See ops/runbooks/redis-topology.md and redis-3-instance-rollout.md.
#
# REDIS_CACHE_HOST=redis-cache
# REDIS_CACHE_PORT=6379
# REDIS_CACHE_PASSWORD=
# REDIS_CACHE_DB=0
#
# REDIS_QUEUE_HOST=redis-queue
# REDIS_QUEUE_PORT=6379
# REDIS_QUEUE_PASSWORD=
# REDIS_QUEUE_DB=0
#
# REDIS_SESSION_HOST=redis-sessions
# REDIS_SESSION_PORT=6379
# REDIS_SESSION_PASSWORD=
# REDIS_SESSION_DB=0
#
# Routing flags — set these in .env.staging / .env.prod alongside the hosts
# above. Without them set, Laravel uses the default single Redis instance.
# SESSION_CONNECTION=sessions
# REDIS_CACHE_CONNECTION=cache
# REDIS_QUEUE_CONNECTION=queue
# HORIZON_REDIS_CONNECTION=queue

# ── Optional dev keyspace isolation (single Redis instance) ────────────────
# Even on a single dev Redis (--databases 4), you can opt into per-role
# keyspace isolation by activating these. With both set, sessions land on
# DB 3 instead of sharing DB 0 with Horizon queues. Same physical instance,
# same allkeys-lru, but keyspaces no longer collide on FLUSHDB / triage.
#
# Trade-off: existing sessions are wiped on cutover (TTL'd anyway, ≤ 2 hr
# session lifetime in this app). Uncomment after first session-loss is
# acceptable.
#
# SESSION_CONNECTION=sessions
# REDIS_SESSION_DB=3


# =============================================================================
# NEO4J COMMUNITY EDITION 2026
# Applies to: neo4j, neo4j-warmup, fastapi, dagster-*
#
# Community Edition: no clustering, no Enterprise warmup, no database RBAC.
# Manual warmup via neo4j-warmup init container.
# =============================================================================

NEO4J_HOST=neo4j
NEO4J_HTTP_PORT=7474
NEO4J_PORT=7687
NEO4J_BOLT_PORT=7687

# Bolt URI used by Dagster and FastAPI Neo4j drivers
NEO4J_URI=bolt://neo4j:7687

# Authentication credentials. Username is conventionally `neo4j`. Password MUST be set before
# first start — compose enforces `NEO4J_PASSWORD:?` and will fail fast if empty.
# Generate a strong password: `openssl rand -hex 32`.
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# NEO4J_AUTH is constructed from the two values above. Do not edit this line directly.
# "none" is NOT a supported value in this stack (Module 2 Phase B, 2026-04-19).
NEO4J_AUTH=${NEO4J_USERNAME}/${NEO4J_PASSWORD}

# Memory tuning — Community Edition (Section 06b)
# Page cache: data on disk cached in RAM. 4G for a 64GB workstation.
NEO4J_PAGECACHE_SIZE=4G

# JVM heap: 2G initial, 4G max.
# Do NOT set these higher than you have free RAM after other services start.
NEO4J_HEAP_INITIAL_SIZE=2G
NEO4J_HEAP_MAX_SIZE=4G


# =============================================================================
# QDRANT v1.17 — vector database
# Applies to: qdrant, fastapi, dagster-*
#
# HNSW m=16, ef_construct=200 are set at the service level.
# Per-collection overrides (payload indices, quantization) are applied by
# the FastAPI service on collection creation.
# =============================================================================

QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# Optional API key for Qdrant. Leave empty to disable auth (dev — network
# isolation is the threat model). Set in a docker-compose.override.yml to
# enable: QDRANT__SERVICE__API_KEY must also be set in the qdrant service.
# See docs/RUNBOOK.md "Qdrant access control".
QDRANT_API_KEY=

# HNSW index parameters — balance between recall quality and memory/build time
# m=16: edges per node (higher = better recall, more memory)
# ef_construct=200: beam width during index build (higher = better quality, slower build)
QDRANT_HNSW_M=16
QDRANT_HNSW_EF_CONSTRUCT=200
# ef: search beam width at query time (higher = better recall, slower query)
QDRANT_HNSW_EF=128


# =============================================================================
# MINIO — S3-compatible object storage
# Applies to: minio, minio-init, laravel-*, dagster-*, ragflow
#
# Bronze layer: immutable raw file archive (drill logs, PDFs, geophysics).
# API port: 9000  |  Console (web UI): 9001
# =============================================================================

# REQUIRED — root credentials for the S3-compatible object store.
# (Variable names keep the MINIO_ prefix for backward compat with code that
# already references them. The actual backend is now SeaweedFS — see
# docs/adr/0001-seaweedfs-replaces-minio.md.)
MINIO_ROOT_USER=georag-admin
MINIO_ROOT_PASSWORD=georag_minio_dev

# Ports exposed to host. Under SeaweedFS the S3 API listens on 8333 (was 9000
# under MinIO); the filer/admin HTTP UI listens on 8888 (no separate console).
MINIO_API_PORT=8333
MINIO_CONSOLE_PORT=8888

# Internal endpoint (service-to-service). Laravel and FastAPI use this URL.
MINIO_ENDPOINT=http://minio:8333

# Bucket names — created automatically by the minio-init container, and also
# auto-created by SeaweedFS on first PUT.
MINIO_BUCKET_BRONZE=bronze
MINIO_BUCKET_EXPORTS=exports
MINIO_BUCKET_BRONZE_RASTER=bronze-raster


# =============================================================================
# AI PROVIDER — laravel/ai SDK default
# =============================================================================

# laravel/ai SDK — provider selection for non-RAG Laravel-side AI calls.
# Production RAG path runs in FastAPI → vLLM. This config is for the
# Laravel-side AI helpers (admin tools, internal helpers).
# Override AI_PROVIDER for premium tier per §08 (e.g. AI_PROVIDER=anthropic for milestone gates).
AI_PROVIDER=openai

# ── MapLibre basemap style URLs (frontend) ──────────────────────────────────
# CLAUDE.md hard rule #8: MapLibre GL (not Mapbox GL) for on-prem licensing.
# Each style URL is independently overridable so air-gapped deployments can
# point at a self-hosted style.json. Defaults are public CDNs requiring no
# API key — fine for cloud/dev, replace for on-prem.
# See config/services.php (basemap.styles) and resources/js/lib/basemap.ts.
# MAPLIBRE_STYLE_POSITRON=https://tiles.openfreemap.org/styles/positron
# MAPLIBRE_STYLE_BRIGHT=https://tiles.openfreemap.org/styles/bright
# MAPLIBRE_STYLE_DARK_MATTER=https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json

# Qwen thinking mode — DEFAULT FOR FREE-TEXT-ONLY callers.
# All grounded-synthesis call sites and every structured/JSON endpoint pass
# enable_thinking=False explicitly at the call site (TOOL-CALL-01 fix).
# This env var only changes the fallback for callers that don't pass an
# explicit value — i.e. exploratory / classifier-escalation paths.
# FALSE (default): safe-by-default, conserves the answer-token budget.
# TRUE: free-text chat may use <think>...</think> reasoning traces.
# Renamed from ENABLE_THINKING (true-default) to make scope explicit —
# see docs/model_migration.md.
ENABLE_THINKING_FREE_TEXT_DEFAULT=false

# Qwen3 sampling parameters — Qwen team's published recommendations.
# Two regimes branch off these in the orchestrator:
#   thinking ON  : temperature=0.7, top_p=0.8, top_k=20, min_p=0
#   thinking OFF : temperature=0.7, top_p=0.8, top_k=20, presence_penalty=1.5
# Override individually if your golden-set sweep finds a better local optimum.
QWEN3_TOP_P=0.8
QWEN3_TOP_K=20
QWEN3_MIN_P=0.0
QWEN3_PRESENCE_PENALTY_NO_THINK=1.5

# MoE review (2026-05-08, item #5): JSON / structured output paths use a
# separate (lower) presence_penalty so the model isn't penalised for
# repeating necessary structural tokens (`{`, `}`, field names). 0.0 is
# the OpenAI-compat default. Raise toward 0.5 only if structured outputs
# show repetition loops in production. Activated by passing
# response_format="json" on `_call_openai_compatible_llm` / `_call_llm`.
QWEN3_PRESENCE_PENALTY_STRUCTURED=0.0

# MoE review (2026-05-08, item #8): widen CPU compute on the offloaded-
# expert path. 0 = let the backend pick (min(physical_cores, 8)); positive
# int overrides per-request. Useful when the 14B dense has 1-3 GB spilled
# to CPU on a 20 GB GPU.
#
# Hardware-refresh (2026-05-08): Kyle's box is a Threadripper Pro 5955WX
# (16 physical / 32 logical). 12 leaves 4 physical cores for FastAPI
# uvicorn (6 workers), Postgres parallel workers, Reverb / Horizon /
# Dagster. Ada/L40S users with everything in VRAM can leave at 0
# (offloaded path is only active when the model spills).
QWEN3_NUM_THREAD=12

# =============================================================================
# LANGFUSE / LANGGRAPH (v1.15 prep — agentic orchestration upgrade)
# Applies to: fastapi (when uv sync --extra langgraph), claude_desktop_config.json,
#             docker/compose.langfuse.yml overlay
#
# Langfuse is the self-hosted, Apache-2.0 agent-trace backend used during
# the LangGraph migration (per ADR-0002 orchestration boundaries — to be
# formalised). Chosen over LangSmith because:
#   * Apache 2.0, no SaaS lock-in
#   * Self-hostable on the existing GeoRAG stack (Postgres + Redis + S3 reused;
#     adds ClickHouse for OLAP traces + 2 Langfuse processes)
#   * Aligns with the air-gapped junior-mining on-prem target
#   * Free for local dev (Cloud free tier also works for SaaS-curious devs)
#
# Bring-up:
#   1. Generate the secrets below (openssl rand -base64 32 / -hex 32)
#   2. docker compose -f docker-compose.yml -f docker/compose.langfuse.yml up -d
#   3. Open http://localhost:3001, sign up (or use the LANGFUSE_INIT_* env
#      vars below to bootstrap a user without going through the UI)
#   4. Settings → API Keys → Create new API key
#   5. Copy the pk-lf-... + sk-lf-... values into claude_desktop_config.json
# =============================================================================

# ----- Self-host service env (consumed by docker/compose.langfuse.yml) -----

# Host port where the Langfuse UI binds (avoid clash with Reverb on 8085).
LANGFUSE_HOST_PORT=3001

# Public URL the Langfuse cookie + email-link flow expects. Set to your
# external hostname when fronting via the Laravel reverse proxy.
LANGFUSE_NEXTAUTH_URL=http://localhost:3001

# Langfuse's own database lives inside the existing georag-postgresql
# instance. Created on first boot by the langfuse-init job in the overlay.
LANGFUSE_DB_NAME=langfuse
LANGFUSE_DB_USER=langfuse_user
# Generate via: openssl rand -base64 24
LANGFUSE_DB_PASSWORD=

# ClickHouse — mandatory new dependency for Langfuse v3 OLAP trace store.
# `langfuse` is the role; the database is created automatically by Langfuse
# migrations on first boot.
CLICKHOUSE_USER=langfuse
# Generate via: openssl rand -base64 24
CLICKHOUSE_PASSWORD=

# S3 buckets in SeaweedFS (georag-minio). Created by Langfuse on first
# write — the AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY values from the
# main S3 config block (above) are reused.
LANGFUSE_S3_EVENT_BUCKET=langfuse-events
LANGFUSE_S3_MEDIA_BUCKET=langfuse-media

# Auth + crypto. ROTATING SALT OR ENCRYPTION_KEY INVALIDATES EVERY
# STORED API KEY AND PROJECT CREDENTIAL — commit to your secret store
# and never rotate without a migration plan.
# Generate via:
#   openssl rand -base64 32        # LANGFUSE_NEXTAUTH_SECRET
#   openssl rand -hex 32           # LANGFUSE_SALT
#   openssl rand -hex 32           # LANGFUSE_ENCRYPTION_KEY
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=
LANGFUSE_ENCRYPTION_KEY=

# Optional first-user bootstrap — leave blank to use the UI sign-up flow.
# Useful for fresh / CI installs where you want a known admin.
LANGFUSE_INIT_ORG_NAME=GeoRAG
LANGFUSE_INIT_PROJECT_NAME=georag-dev
LANGFUSE_INIT_USER_EMAIL=
LANGFUSE_INIT_USER_NAME=
LANGFUSE_INIT_USER_PASSWORD=

# ----- Tracing client config (consumed by FastAPI / LangGraph) -----

# When true, the LangGraph migration's in-process tracer ships traces to
# Langfuse. Off by default to avoid leaking traces during local-only
# debugging; flip on in staging/prod via the relevant compose overlay.
LANGFUSE_TRACING=false

# API endpoint for the tracing client. Use the internal docker hostname
# when FastAPI ships traces in-process (preferred), or localhost:3001
# when running outside Docker. Set to https://cloud.langfuse.com for the
# Cloud free tier instead of self-host.
LANGFUSE_HOST=http://langfuse-web:3000

# API keys — generated AFTER first sign-in via Langfuse UI → Settings →
# API Keys → Create. The pk-lf-... is public, sk-lf-... is secret;
# both are required by the SDK.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Project tag in Langfuse traces — matches what the UI displays.
LANGFUSE_PROJECT=georag-dev


# =============================================================================
# LLM CONFIGURATION
# Applies to: fastapi
#
# Backends — select via LLM_BACKEND:
#   vllm       (default)         → vLLM serving Qwen3-14B-AWQ via the
#                                  OpenAI-compatible /v1/chat/completions
#                                  endpoint. Same shape across dev and prod;
#                                  hardware tier and quant change.
#   anthropic  (prod fallback)   → Claude API (native SDK; unlocks prompt
#                                  caching, adaptive thinking, priority
#                                  tier, the 300k-output batch beta).
#
# Context budgets (MAX_CONTEXT_*) default to sane values for the OpenAI-
# compat path's working window. When using the Anthropic backend on
# Opus 4.7 (1M ctx) or Sonnet 4.6 (1M ctx), raise MAX_CONTEXT_TOKENS to
# ~200000 and the per-category caps 5-10× to ground synthesis queries on
# the full corpus of retrieved data.
# =============================================================================

# Which backend the FastAPI orchestrator calls for the summary LLM call.
# Options: vllm | anthropic
LLM_BACKEND=vllm

# Fallback behaviour when the primary backend fails or rate-limits:
#   downshift  — retry with a smaller/cheaper model on the same backend
#   local_llm  — route to the local vLLM endpoint (requires vllm profile
#                running).
#   off        — no fallback, surface the error immediately
LLM_BACKEND_FALLBACK=downshift

# Primary backend URL — only used when LLM_BACKEND=vllm.
LLM_PRIMARY_URL=http://vllm:8000/v1

# Model name sent to the primary backend. Must be served by vLLM.
LLM_PRIMARY_MODEL=Qwen/Qwen3-14B-AWQ

# ── Anthropic backend ──────────────────────────────────────────────────
# Only used when LLM_BACKEND=anthropic. Get a key at console.anthropic.com.
ANTHROPIC_API_KEY=

# Default model: claude-opus-4-7 (strongest agentic coding, 1M ctx, adaptive
# thinking). Alternatives: claude-sonnet-4-6 (cheaper/faster, 1M ctx) or
# claude-haiku-4-5 (fast path, 200k ctx) for the summary call.
ANTHROPIC_MODEL=claude-opus-4-7

# Max tokens the model may emit in a single response. Opus 4.7 supports up
# to 128k; 4096 is a sensible default for the GeoRAG summary task.
ANTHROPIC_MAX_OUTPUT_TOKENS=4096

# Enable Anthropic prompt caching on the static system prompt. This cuts
# input cost ~90% and first-token latency ~60-80% on cache hits. Leave on.
ANTHROPIC_ENABLE_PROMPT_CACHING=true

# Priority tier buys guaranteed throughput at a cost premium. Leave off
# for development; enable in production if standard-tier 429s bite.
ANTHROPIC_USE_PRIORITY_TIER=false

# Model tier aliases — FastAPI orchestrator selects the right model per task
# complexity. Defaults below match claude.ai naming as of 2026-04.
# Fast  = lightweight tasks (routing, query rewrite, entity extraction)
# Standard = main RAG synthesis calls
# Deep = complex reasoning, long-context geological interpretation
MODEL_TIER_FAST=claude-haiku-4-5
MODEL_TIER_STANDARD=claude-sonnet-4-5
MODEL_TIER_DEEP=claude-opus-4-7

# ── Batch API (Dagster ingestion assets) ────────────────────────────────
# The same ANTHROPIC_API_KEY feeds both the synchronous path (FastAPI
# orchestrator) and the Batch API (Dagster bulk enrichment). The batch
# path is ~50% cheaper per token and is intended for non-interactive
# work: per-report entity extraction, chunk tagging, constraint auditing.
# Dagster assets that want extended output (300k tokens/response on Opus
# 4.7 / Sonnet 4.6) construct the client with extended_output=True —
# no env var needed for that flag today.
#
# Nothing else to configure here until an asset wires up an LLM step.

# ── Context budget (applies to all backends) ────────────────────────────
# The orchestrator caps retrieved data per category before prompting the LLM.
# Defaults fit qwen3-14b-awq (16K ctx — current primary). Raise when
# LLM_BACKEND=anthropic, or when rolling back to qwen2.5:14b (32K ctx).
#
# Suggested tunings:
#   vllm qwen3-14b-awq (A4500 20 GB):
#     MAX_CONTEXT_TOKENS=22000 COLLARS=30 DOC_CHUNKS=8 GRAPH_ENTITIES=30 PG_RECORDS=20
#   vllm qwen3-14b-awq (16 GB GPU, prior era):
#     MAX_CONTEXT_TOKENS=15000 COLLARS=20 DOC_CHUNKS=5 GRAPH_ENTITIES=20 PG_RECORDS=12
#   anthropic:
#     MAX_CONTEXT_TOKENS=200000 COLLARS=100 DOC_CHUNKS=30 GRAPH_ENTITIES=100 PG_RECORDS=60
#
# Hardware-refresh (2026-05-08): bumped to A4500 20 GB profile. The +7000
# tokens of context budget (vs the 16 GB era) = ~3 extra document
# chunks or ~10 extra collar rows surface to grounded synthesis without
# truncation.
MAX_CONTEXT_TOKENS=22000
MAX_CONTEXT_COLLARS=30
MAX_CONTEXT_DOC_CHUNKS=8
MAX_CONTEXT_GRAPH_ENTITIES=30
MAX_CONTEXT_PG_RECORDS=20

# Max self-correction retries after validator flags (Layer 3/4/6). Default
# is 2 — drop to 1 when LLM_BACKEND=anthropic since Opus 4.7's adaptive
# thinking self-corrects during the first call for most issues.
MAX_VALIDATION_RETRIES=2

# Per-call cap on the visible answer tokens emitted by the OpenAI-compatible
# backend (vLLM). Mirrors ANTHROPIC_MAX_OUTPUT_TOKENS. Stops a small model
# stuck in a repetition loop from burning the FastAPI deadline.
LLM_MAX_OUTPUT_TOKENS=4096

# Extra num_predict budget added on free-text-with-thinking calls. Qwen3
# reasoning trace tokens go to the `reasoning` field but still draw from
# the response token budget, so without a bump the visible answer gets
# truncated when thinking is on. Set to 0 to disable. 2048 covers a
# typical 1-2K reasoning trace on grounded queries.
LLM_MAX_THINKING_TOKENS=2048

# ── Legacy OpenAI-compatible fallback ───────────────────────────────────
# Pre-Anthropic integration knob. For new installs, prefer LLM_BACKEND=anthropic
# instead of configuring these. Kept for back-compat with existing proxies.
LLM_FALLBACK_URL=
LLM_FALLBACK_ENABLED=false
LLM_FALLBACK_API_KEY=

# Minimum retrieval quality score (0.0–1.0) below which the RAG pipeline
# rejects the result rather than prompting the LLM with low-quality context.
# Matches the hallucination prevention threshold in Section 04i.
RETRIEVAL_QUALITY_THRESHOLD=0.6


# =============================================================================
# vLLM — OpenAI-compatible GPU inference server
# Applies to: vllm, fastapi
#
# vLLM is the primary LLM serving backend across both dev and prod.
#
# Default model: Qwen3-14B-AWQ Instruct AWQ (W4A16, Marlin INT4 kernels).
# Sized for the dev workstation's RTX A4500 (20 GB VRAM, compute 8.6 —
# Ampere, no native FP8). AWQ INT4 weights are ~17 GB; KV cache budget
# at max-model-len=8192 is ~2 GB at gpu-memory-utilization=0.95.
#
# On larger GPUs (A6000, L40S, H100) raise VLLM_MAX_MODEL_LEN to 16384 or
# 32768 and consider switching to GPTQ-Int8 / BF16 for higher quality.
# On smaller GPUs (16 GB or less), switch to Qwen3-14B-AWQ.
# =============================================================================

# Host port for vLLM's OpenAI-compatible API (container internal: 8000)
VLLM_PORT=8001

# Internal URL that FastAPI uses to reach vLLM
VLLM_URL=http://vllm:8000/v1

# HuggingFace model ID to load. Must fit in your GPU VRAM. See the vLLM
# service definition for the exact serve flags.
VLLM_MODEL=Qwen/Qwen3-14B-AWQ

# Model name advertised on /v1/models. Keep aligned with VLLM_MODEL unless
# you have a routing reason to alias it.
VLLM_SERVED_MODEL_NAME=Qwen/Qwen3-14B-AWQ

# Quantization kernel selector passed to `--quantization`.
#   awq_marlin  — AWQ INT4 with Marlin kernels (Ampere+, near-FP16 throughput)
#   gptq_marlin — GPTQ INT4 equivalent
#   (empty)     — unquantized BF16 / FP16 (only viable on hardware with the
#                 VRAM to hold full-precision weights)
VLLM_QUANTIZATION=awq_marlin

# Maximum sequence length (prompt + completion, in tokens). Reduce if OOM
# during model load. On A4500 + AWQ 14B, 8192 is the safe ceiling.
VLLM_MAX_MODEL_LEN=8192

# Fraction of GPU VRAM vLLM may use for weights + KV cache (0.0–1.0).
# 0.92 is the realistic ceiling for the A4500 *as a desktop card* —
# Windows desktop compositing permanently holds ~1-1.5 GiB that the GPU
# compositor won't release. Headless A4500 hardware can push to 0.95+.
# Lower further (0.85-0.90) if embeddings or reranker share the device.
VLLM_GPU_MEM_UTIL=0.92

# Maximum concurrent sequences the vLLM engine will schedule. vLLM
# defaults to ~256 (sized for H100/A100); on the A4500 every concurrent
# sequence claims KV-pool slots and over-subscribing leads to swap or
# OOM (exit 137). 8 matches the ADR-0001 burst target (2 sustained /
# 4-6 burst, with headroom for warm-pool churn). Raise on larger GPUs.
VLLM_MAX_NUM_SEQS=12

# Number of GPUs for tensor parallelism. Must match VLLM_GPU_COUNT below.
# On the dev A4500 this is 1; raise on multi-GPU prod hardware.
VLLM_TENSOR_PARALLEL=1

# Number of GPU devices to reserve via the Docker NVIDIA runtime.
VLLM_GPU_COUNT=1

# HuggingFace access token — needed for gated repos (some Llama, Mistral
# tiers). The default Qwen3 AWQ repo is public, but set this anyway for
# forward-compat with model swaps.
# Get one at https://huggingface.co/settings/tokens
HF_TOKEN=


# =============================================================================
# LARAVEL REVERB — WebSocket server
# Applies to: laravel-reverb, laravel-octane (broadcasting config)
#
# React clients connect to Reverb for real-time LLM token streaming.
# =============================================================================

# REQUIRED — generate with: openssl rand -base64 32
REVERB_APP_ID=georag-app
REVERB_APP_KEY=georag-reverb-key
REVERB_APP_SECRET=georag-reverb-secret

REVERB_HOST=0.0.0.0
# Host port for Reverb WebSocket. Default 8080 often conflicts — use 8085 if so.
REVERB_PORT=8085
# Internal container port Reverb listens on (mapped to REVERB_HOST_PORT on the host)
REVERB_HOST_PORT=8085
REVERB_SCHEME=http


# =============================================================================
# MARTIN — PostGIS vector tile server (MapLibre GL)
# Applies to: martin
#
# Profile: dev-light — starts alongside the Laravel app layer.
# Serves geological vector layers (collars, drill traces, boundaries) as MVT
# tiles directly from PostGIS SQL function sources.
# =============================================================================

# Host port for Martin tile server (internal: 3000)
MARTIN_PORT=3002


# =============================================================================
# FASTAPI — Python domain service
# Applies to: fastapi, laravel-octane, laravel-horizon
#
# Service-to-service auth: Laravel sends X-Service-Key header with every
# internal request to FastAPI. FastAPI rejects requests without a valid key.
# =============================================================================

FASTAPI_HOST=fastapi
FASTAPI_PORT=8000

# uvicorn worker count (hardware-refresh 2026-05-08).
# Threadripper Pro 5955WX (16 physical / 32 logical cores) on the
# dedicated dev workstation comfortably runs 6 workers without
# starving Postgres parallel workers (max_parallel_workers=12),
# vLLM offload threads (QWEN3_NUM_THREAD=12), or Dagster ingestion.
# Drop to 4 on smaller hardware (8-core / 16-thread); raise to 8 on
# >32-core servers. Each worker holds its own asyncpg pool + httpx
# pool, so don't over-provision.
UVICORN_WORKERS=6

# REQUIRED — shared secret for Laravel→FastAPI service auth.
# Also used as the HS256 signing secret for the short-TTL per-request JWTs
# that Laravel mints (see App\Services\FastApiJwtMinter, B7). FastAPI must
# hold the identical value under LARAVEL_SERVICE_KEY to verify signatures.
#
# MUST BE >= 32 bytes (256 bits). Both sides enforce this at boot (R13):
#   - FastAPI: Pydantic validator on Settings.FASTAPI_SERVICE_KEY
#   - Laravel: FastApiJwtMinter::mint() throws on a short secret
# The default placeholder below is intentionally a long string so new
# installs don't immediately fail validation — replace it for any
# non-local deployment.
# Generate with: python3 -c 'import secrets; print(secrets.token_urlsafe(48))'
FASTAPI_SERVICE_KEY=REPLACE_ME_WITH_A_48_BYTE_TOKEN_URLSAFE_STRING_AT_LEAST_32_BYTES

# V1.5-03 — `kid` header on every minted JWT. Default `primary` matches the
# FastAPI `FASTAPI_SERVICE_KEY_KID` default. To rotate: stage the new key as
# FASTAPI_SERVICE_KEY_PREVIOUS on FastAPI side first, then bump this kid to
# something like `2026-q3`. See ops/runbooks/secret-rotation.md for steps.
FASTAPI_SERVICE_KEY_KID=primary

# V1.5-03 — optional rotation overlap. Set FASTAPI_SERVICE_KEY_PREVIOUS_KID +
# FASTAPI_SERVICE_KEY_PREVIOUS on the FastAPI side during a rotation window
# so both keys decode successfully. Leave empty in steady state.
# FASTAPI_SERVICE_KEY_PREVIOUS_KID=
# FASTAPI_SERVICE_KEY_PREVIOUS=


# =============================================================================
# CROSS-DATABASE TIMEOUTS (Section 06e)
# Applies to: fastapi
#
# These cap individual database calls. asyncio.gather collects all results
# with an overall deadline of TIMEOUT_GATHER_S. Partial results are returned
# rather than failing the entire request on a single slow store.
# =============================================================================

# PostGIS/PostgreSQL query timeout (seconds)
TIMEOUT_POSTGIS_S=5

# Neo4j Cypher query timeout (seconds) — investigate queries that exceed 3s
TIMEOUT_NEO4J_S=3

# Qdrant vector search timeout (seconds)
TIMEOUT_QDRANT_S=2

# Redis cache operation timeout (milliseconds)
TIMEOUT_REDIS_MS=500

# Overall asyncio.gather deadline (seconds) — covers parallel fan-out across all stores
# Module 6 Chunk 3.5 2026-04-22: raised to 180 to accommodate four §04i guards
# (numeric + entity + completeness + refusal) running synchronously after LLM synthesis.
# On the dev GPU (RTX 4080, qwen3-14b-awq, ~14.6 tok/s), the full pipeline fits in 180s.
# Prod GPU with higher TPS can use a lower value (e.g., 120 or 90).
TIMEOUT_GATHER_S=180


# =============================================================================
# DAGSTER — ingestion pipeline orchestration
# Applies to: dagster-daemon, dagster-webserver
#
# Profile: dev-ingest — start only during ingestion pipeline development.
# Dagster stores run history and event logs in its own PostgreSQL schema.
# Both dagster-daemon AND dagster-webserver must run — they are separate processes.
# =============================================================================

# Dagster home directory — persisted in a named volume
DAGSTER_HOME=/opt/dagster/dagster_home

# Dagster webserver port
DAGSTER_WEBSERVER_PORT=3001

# PostgreSQL connection for Dagster's own run storage and event log.
# RECOMMENDED: use a separate database from the application DB for cleanliness.
DAGSTER_PG_HOST=pgbouncer
DAGSTER_PG_PORT=6432
DAGSTER_PG_DB=georag_dagster
DAGSTER_PG_USER=georag

# REQUIRED — can be the same password as POSTGRES_PASSWORD if using same user
DAGSTER_PG_PASSWORD=georag_dev_password


# =============================================================================
# RAGFLOW — document parsing and chunking
# Applies to: ragflow
#
# Profile: dev-ingest — start only during document ingestion work.
# RAGFlow handles PDF extraction, OCR, and document-aware chunking before
# embeddings are written to Qdrant.
# =============================================================================

RAGFLOW_PORT=9380


# =============================================================================
# PROMETHEUS — metrics collection
# Applies to: prometheus
#
# Profile: dev-monitor — skip by default.
# Scrapes FastAPI /metrics, Laravel Pulse export, and database exporters.
# =============================================================================

PROMETHEUS_PORT=9090

# Prometheus retention period for time-series data
PROMETHEUS_RETENTION=7d


# =============================================================================
# ALERTMANAGER — alert routing
# Applies to: alertmanager
#
# Profile: dev-monitor — starts alongside Prometheus.
# Routes alerts to webhook receivers (Slack/PagerDuty/email — configure in
# docker/alertmanager/alertmanager.yml).
# =============================================================================

ALERTMANAGER_PORT=9093


# =============================================================================
# LOKI — log aggregation
# Applies to: loki
#
# Profile: dev-monitor — starts alongside Prometheus and Grafana.
# Promtail tails Laravel + FastAPI log files and ships JSON to Loki.
# Grafana queries via LogQL.
# =============================================================================

LOKI_PORT=3100


# =============================================================================
# PROMETHEUS EXPORTERS — database metrics bridges
# Applies to: redis_exporter, postgres_exporter, neo4j_exporter
#
# Profile: dev-monitor — start alongside Prometheus.
# These expose native database metrics in Prometheus exposition format.
#   redis_exporter    — oliver006/redis_exporter, MIT license
#   postgres_exporter — prometheuscommunity/postgres-exporter, Apache-2.0
#   neo4j_exporter    — georag/neo4j-exporter (local build), JMX→Prometheus sidecar
# =============================================================================

REDIS_EXPORTER_PORT=9121
POSTGRES_EXPORTER_PORT=9187
NEO4J_EXPORTER_PORT=9105


# =============================================================================
# GRAFANA — dashboards
# Applies to: grafana
#
# Profile: dev-monitor — skip by default.
# Access at http://localhost:3000
# =============================================================================

GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin

# REQUIRED — set a strong password even in dev (Grafana is a web UI)
GRAFANA_ADMIN_PASSWORD=georag_grafana_dev

GRAFANA_ROOT_URL=http://localhost:3000


# =============================================================================
# LARAVEL FRAMEWORK — DB / CACHE / SESSION / QUEUE
# These map GeoRAG infrastructure vars to the names Laravel config files expect.
# DB connects through PgBouncer (port 6432), never PostgreSQL directly (5432).
# =============================================================================

DB_CONNECTION=pgsql
DB_HOST=pgbouncer
DB_PORT=6432
DB_DATABASE="${POSTGRES_DB}"
DB_USERNAME="${POSTGRES_USER}"
DB_PASSWORD="${POSTGRES_PASSWORD}"

CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

# Max concurrent LLM streaming workers (supervisor-llm in config/horizon.php).
# Must be <= FastAPI /internal/queries concurrency and the vLLM slot count.
# Each worker holds one open SSE connection for the full query duration.
HORIZON_LLM_MAX_PROCESSES=2

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
MAIL_MAILER=log

OCTANE_SERVER=swoole

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# V1.5-12 — Map base layers (DEM + satellite). Default empty here so the
# SPA falls back to the public CDNs (Mapterhorn DEM + EOX Sentinel-2). On-prem
# deployments override these with self-hosted Martin or nginx URLs. See
# ops/runbooks/dem-self-host.md for the self-hosting procedure.
# VITE_DEM_TILES_URL=https://tiles.mapterhorn.com/tilejson.json
# VITE_SATELLITE_TILES_URL=https://tiles.maps.eox.at/wmts/1.0.0/s2cloudless-2020_3857/default/g/{z}/{y}/{x}.jpg


# =============================================================================
# BACKUP CONFIGURATION (BK-01/BK-02/BK-05/BK-06 fix — 2026-04-19 infra audit)
# Applies to: postgresql, neo4j, qdrant (backup scripts executed by Ofelia)
#
# Backups are staged locally then uploaded to SeaweedFS via AWS CLI S3 API.
# The backup destination uses the same MINIO_* credentials as the object store
# (SeaweedFS keeps the MINIO_* naming convention per ADR-0001 compatibility).
#
# Primary destination: s3://georag-backups/ on SeaweedFS
# Staging volume: backup_staging (named Docker volume, ephemeral — cleared after upload)
# =============================================================================

# S3-compatible endpoint for backup uploads. Points at SeaweedFS S3 API.
# Uses the same endpoint as MINIO_ENDPOINT — defined here separately for
# scripts that run in containers that may not have MINIO_ENDPOINT set.
# Format: http://<host>:<port>  (no trailing slash)
S3_ENDPOINT_URL=http://minio:8333

# AWS CLI credentials for backup uploads to SeaweedFS.
# These match the SeaweedFS root credentials (MINIO_ROOT_USER / MINIO_ROOT_PASSWORD).
# Scripts read these directly — do not share with untrusted services.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Retention in days — backups older than this are deleted from S3 automatically
# by the retention sweep at the end of each backup script.
BACKUP_RETENTION_DAYS=7

# Neo4j database name to back up. Default "neo4j" is the default system database.
# If you have additional databases, run the script once per database name.
NEO4J_DB_NAME=neo4j

# Backup agent additional vars (2026-04-19 Module 1 Phase B)
# AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, and S3_ENDPOINT_URL are defined
# above — these additional vars are also consumed by the backup-agent sidecar.
NEO4J_BACKUP_CONTAINER=georag-neo4j
NEO4J_IMAGE=
QDRANT_URL=http://qdrant:6333

# ---------------------------------------------------------------------------
# Module 6 Phase B Chunk 2+3 — Citation span resolver
# ---------------------------------------------------------------------------
# When true, the post-gen span resolver parses answer text for citation
# markers in colon form ([DATA:N], [NI43:N], [PUB:N], [PGEO:N], [ev:<id>]),
# computes character offsets, and writes rows to silver.answer_citation_items
# + silver.answer_citation_spans.  Also enables four §04i guards (numeric,
# entity, completeness, refusal meta-guard).
#
# LIVE state: Chunk 3.6 (2026-04-22) — flag confirmed live after prompt trim.
# v9 preamble trimmed to byte-parity with v8 (3298 chars each). S1 smoke
# passed at 87.3s warm wall time on RTX 4080 / qwen3-14b-awq. Colon-form
# markers [DATA:N] confirmed in model output. Lifecycle draft->committed live.
# See ops/audit/2026-04-21-citation-guards-audit.md Chunk 3.6 section.
#
# Set to false in new installs until the citation pipeline review is
# completed for that deployment context. FastAPI restart required on flip.
CITATION_SPAN_RESOLVER_ENABLED=true

# ---------------------------------------------------------------------------
# Phase 2.1 (2026-05-22) — fitz-first dispatch with docling OCR on image pages
# ---------------------------------------------------------------------------
# When true, the parser routes image pages (where fitz returned
# < PER_PAGE_MIN_CHARS) to docling for layout-aware extraction + OCR.
# Docling's TableFormer + layout model run on GPU via onnxruntime-gpu
# when CUDA is available. Text-only pages are still handled by fitz —
# docling only fires when there is actual image content to OCR.
# Default true after Phase 2.1 smoke. Set false to revert to the
# fitz+tesseract-only dispatch.
PDF_PARSER_DOCLING_ENABLED=true

# When true AND PDF_PARSER_DOCLING_ENABLED=true, docling uses rapidocr
# for OCR on image pages. Required for the docling-as-primary-OCR path.
# Default true after Phase 2.1 smoke confirmed rapidocr fires on cuda:0
# with the writable model cache. Flip to false to keep docling for
# tables + figures only and let tesseract handle OCR.
DOCLING_OCR_ENABLED=true

# Phase 2.1 kickoff requirement — tesseract is the fallback-of-last-
# resort for image pages when docling is unavailable or fails. Required
# for no-data-loss on hosts without GPU / when docling import breaks.
PDF_PARSER_TESSERACT_FALLBACK_ENABLED=true

# 2026-05-23: Opt-in flag for docling's GPU layout + TableFormer path.
# Docling on CUDA drops parse from ~30 min to ~3-5 min per big NI 43-101
# BUT competes with vLLM for VRAM. The A4500 at vLLM gpu-memory-utilization
# 0.93 leaves ~1.5 GiB free; docling layout needs ~1-2 GiB and PaddleOCR
# PP-StructureV3 needs ~1.5-2 GiB. Both together OOM vLLM.
#
# Set true ONLY on a worker pool that does NOT share VRAM with vLLM
# (e.g. hatchet-worker-ai on a second GPU, or a host where vLLM runs
# on a different card). Default false to keep ingest CPU-bound and safe.
DOCLING_GPU_ENABLED=false

# Rapidocr ONNX model cache. Default location is inside Python's
# site-packages which is read-only for www-data. We redirect to a
# writable named-volume mount so rapidocr can download its ~150 MB of
# per-language ONNX models once per host and reuse on every parse.
# Change this only if you've remapped the named volume mount point in
# docker-compose.yml.
RAPIDOCR_MODEL_DIR=/tmp/rapidocr_models

# Comma-separated list of rapidocr languages. "english" is sufficient
# for NI 43-101 corpora. Add others (e.g. "english,chinese") if the
# document set requires it — each language pulls additional ONNX
# weights into RAPIDOCR_MODEL_DIR on first call.
DOCLING_OCR_LANGS=english

# §04p dual-write toggle. Read by the p04p_dual_write Hatchet task.
# Default true after re-enable on 2026-05-22 — the §04p task runs
# parallel to persist with its own execution_timeout, so it can't
# starve the main persist path.
P04P_DUAL_WRITE_ENABLED=true

# Page-level parallelism inside a single pdfplumber parse. Default 4
# so two parses can run on 8 cores without fighting; bump up on
# headless boxes with more cores. Set to 1 for sequential debugging.
PDF_PARSE_PAGE_WORKERS=4

# ---------------------------------------------------------------------------
# Phase 4 (2026-05-22) — table extraction overhaul
# ---------------------------------------------------------------------------
# Per-page classification thresholds for the bordered-vs-borderless
# router. Bordered pages (≥ either threshold) prefer docling TableFormer;
# borderless pages get the pdfplumber text strategy only. Tune up if
# your corpus has lots of decorative rectangles unrelated to tables.
TABLE_BORDER_LINE_THRESHOLD=3
TABLE_BORDER_RECT_THRESHOLD=20

# Minimum bordered page count required to invoke docling-tables-only.
# Below this count, pdfplumber-lines handles the bordered pages — for
# small PDFs (slide decks, prospectuses with 5-15 bordered pages) the
# ~30-40s docling startup overhead is a net loss; for full NI 43-101
# technical reports (typically 50-100+ bordered table pages) docling
# is the clear win. Default 30 lands in the middle.
PDF_PARSER_DOCLING_TABLES_MIN_BORDERED_PAGES=30

# ---------------------------------------------------------------------------
# Phase 5 (2026-05-22) — subprocess pool sizing + memory guard
# ---------------------------------------------------------------------------
# Number of PDFs the parse task can process in parallel per worker.
# Previously hardcoded to 1, which meant Hatchet's 20-slot ingestion
# pool serialized parses through one subprocess. Leaving this empty
# defers to min(os.cpu_count(), 4) — safe default for an 8-core
# workstation. Override to 1 to revert to legacy single-parse.
PARSE_SUBPROCESS_MAX_WORKERS=

# Minimum available RAM (MB) before submitting a parse to the pool.
# Default raised 2026-05-23 from 1500 → 4500 after the TIFF smoke
# proved a single docling parse needs ~3-4 GB resident
# (PaddleOCR + RapidOCR + transformers + layout model). The old 1500 MB
# threshold passed even when a parse would OOM-kill the subprocess.
# On a memory-tight host you can lower this BUT you must also disable
# docling (PDF_PARSER_DOCLING_ENABLED=false) to stay under budget.
# See [[tiff-smoke-2026-05-23]] for the OOM root-cause analysis.
PARSE_MIN_FREE_RAM_MB=4500

# Max seconds the parse task waits for memory headroom before raising
# MemoryError. Hatchet's parse.retries=1 catches it and tries on a
# freer worker. Default raised 2026-05-23 from 30 → 120 because the
# per-workspace concurrency cap (Q) means parses now QUEUE — a 30 s
# wait was a hangover from the unbounded-concurrency era. 120 s gives
# transient pressure (e.g. a competing workspace's parse) room to
# clear instead of giving up immediately.
PARSE_MEMORY_WAIT_MAX_S=120

# ---------------------------------------------------------------------------
# Phase 9 (2026-05-22) — PaddleOCR GPU acceleration (§04p stack)
# ---------------------------------------------------------------------------
# Selects between GPU (PP-OCRv5 via paddlepaddle-gpu) and CPU paths.
#   ""    (empty / auto)  Use GPU when paddle is compiled with CUDA AND
#                         free VRAM ≥ PADDLEOCR_MIN_FREE_VRAM_MB.
#                         Falls back to CPU otherwise (graceful, logged).
#   true  Force GPU. Logs a warning + falls back to CPU if paddle is
#         CPU-built or VRAM is tight.
#   false Force CPU regardless of GPU availability.
# Set to "true" on the ingestion worker after paddlepaddle-gpu is
# installed (image rebuild OR docker-compose worker bootstrap pulls it
# from the Paddle cu126 index on next restart). The bootstrap is
# guarded by this env so a "true" setting kicks off the install.
PADDLEOCR_USE_GPU=

# Sanity check before grabbing GPU. PaddleOCR PP-OCRv5 peaks at ~1-2 GB
# VRAM. Default 1024 leaves a safety margin so we don't OOM the GPU
# when vLLM is already at its 0.80 mem_util cap. Raise on shared GPUs.
PADDLEOCR_MIN_FREE_VRAM_MB=1024

# ---------------------------------------------------------------------------
# Phase 6 (2026-05-22) — OCR Quality Agent
# ---------------------------------------------------------------------------
# When true, the ocr_quality_check workflow runs after every persist to
# evaluate each passage's ocr_confidence + text for known artifacts.
# Below OCR_REOCR_THRESHOLD or artifact match → dispatch re_ocr_page
# for that passage's page. Below OCR_QUALITY_THRESHOLD only → mark
# ocr_status='low_confidence' (informational, no re-OCR).
# Default false during staged rollout — flip to true after smoke.
OCR_QUALITY_AGENT_ENABLED=false

# Passage confidence at/above this is "accepted" (no flag). Default 0.75.
# fitz_native and pdfplumber_native passages always pass (ocr_confidence
# is NULL — quality agent skips them).
OCR_QUALITY_THRESHOLD=0.75

# Below this threshold (or with a detected artifact pattern), the agent
# dispatches re_ocr_page. Default 0.60 — well below the docling default
# 0.90, generally only OCR'd-and-marginal passages.
OCR_REOCR_THRESHOLD=0.60

# Per-document cap on automatic re-OCR dispatches. Above this, the
# agent stops dispatching and inserts a single silver.review_queue row
# (target_record_kind='ocr_quality_review') for operator review.
# Default 20 keeps re-OCR cost bounded on heavily-degraded scans.
OCR_MAX_REOCR_PAGES_PER_DOC=20
