        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^6.0.0",
        "axios": ">=1.16.1 <2.0.0",
        "concurrently": "^9.0.1",
        "jsdom": "^29.0.2",
        "laravel-vite-plugin": "^3.0.0",
        "tailwindcss": "^4.3.0",
        "typescript": "^6.0.2",
        "vite": "^8.0.0",
        "vitest": "^4.1.4"
    }
