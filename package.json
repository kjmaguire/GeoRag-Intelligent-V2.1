{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "bash scripts/guard-build-perms.sh && vite build",
        "build:ssr": "bash scripts/guard-build-perms.sh && vite build --ssr",
        "build:fix-perms": "bash scripts/guard-build-perms.sh --fix",
        "dev": "vite",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@fontsource/inter-tight": "^5.2.7",
        "@fontsource/jetbrains-mono": "^5.2.8",
        "@inertiajs/react": "^2.0.0",
        "@xyflow/react": "^12.10.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "jszip": "^3.10.1",
        "laravel-echo": "^2.3.4",
        "lucide-react": "^1.8.0",
        "maplibre-gl": "^5.23.0",
        "plotly.js-dist-min": "^3.5.0",
        "proj4": "^2.20.8",
        "pusher-js": "^8.5.0",
        "radix-ui": "^1.4.3",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-map-gl": "^8.1.0",
        "react-markdown": "^10.1.0",
