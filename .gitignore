/.phpunit.cache
/node_modules
/public/build
/public/hot
/public/storage
/storage/*.key
/vendor
.env
.env.backup
.env.production
.phpactor.json
auth.json
Homestead.json
Homestead.yaml
npm-debug.log
yarn-error.log
/.fleet
/.idea
/.nova
/.vscode

# Security — never commit secrets or credentials
*.pem
*.key
*.p12
*.pfx
!storage/*.key
credentials.json
service-account.json
docker/secrets/

# Backups — too large for git
backups/

# Python virtual environments
src/fastapi/.venv/
src/dagster/.venv/
__pycache__/
*.pyc

# Test fixtures: PDFs are generated by scripts, not committed
tests/fixtures/reports/*.pdf

# Laravel runtime artifacts
.phpunit.result.cache
/bootstrap/cache/*
!/bootstrap/cache/.gitignore
/storage/app/private/*
!/storage/app/private/.gitignore
/storage/app/public/*
!/storage/app/public/.gitignore
/storage/app/*.php
/storage/framework/cache/*
!/storage/framework/cache/.gitignore
/storage/framework/sessions/*
!/storage/framework/sessions/.gitignore
/storage/framework/testing/*
!/storage/framework/testing/.gitignore
/storage/framework/views/*
!/storage/framework/views/.gitignore
/storage/logs/*
!/storage/logs/.gitignore

# Playwright debug screenshots
/.playwright-mcp/

# Operator-generated SOPS encrypted files (commit when ready, see OPERATOR-AFTERNOON.md)
# /.env.production.enc is intentionally NOT ignored — it's safe to commit when SOPS-encrypted.
.verifier-state/

# Phase H — guard against Windows host path leakage when running
# pip install --target inside the fastapi container with a Unix-style
# /tmp path. Docker's bind mount translates this to a Windows path
# and the wheel set lands as 'src/fastapi/C:/Users/...' in the repo.
src/fastapi/C:/

# §5b — golden-query benchmark reports. Reports include git_sha +
# timestamp in the filename and may be 100s of KB each; track them
# in an operations repo or as CI artifacts, not the source tree.
# Keep the directory so first-time runs don't error.
src/fastapi/bench_results/*.json
!src/fastapi/bench_results/.gitkeep
