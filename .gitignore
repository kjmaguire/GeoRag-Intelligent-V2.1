# Security — never commit secrets or credentials
*.pem
*.key
*.p12
*.pfx
!storage/*.key
credentials.json
service-account.json
docker/secrets/

# Backups — too large for git
backups/

# Python virtual environments
src/fastapi/.venv/
src/dagster/.venv/
__pycache__/
*.pyc

# Test fixtures: PDFs are generated by scripts, not committed
tests/fixtures/reports/*.pdf

# Laravel runtime artifacts
.phpunit.result.cache
/bootstrap/cache/*
!/bootstrap/cache/.gitignore
/storage/app/private/*
!/storage/app/private/.gitignore
/storage/app/public/*
!/storage/app/public/.gitignore
/storage/app/*.php
/storage/framework/cache/*
!/storage/framework/cache/.gitignore
/storage/framework/sessions/*
!/storage/framework/sessions/.gitignore
/storage/framework/testing/*
!/storage/framework/testing/.gitignore
/storage/framework/views/*
!/storage/framework/views/.gitignore
/storage/logs/*
!/storage/logs/.gitignore

# Playwright debug screenshots
/.playwright-mcp/

# Operator-generated SOPS encrypted files (commit when ready, see OPERATOR-AFTERNOON.md)
# /.env.production.enc is intentionally NOT ignored — it's safe to commit when SOPS-encrypted.
.verifier-state/

# Phase H — guard against Windows host path leakage when running
# pip install --target inside the fastapi container with a Unix-style
# /tmp path. Docker's bind mount translates this to a Windows path
# and the wheel set lands as 'src/fastapi/C:/Users/...' in the repo.
src/fastapi/C:/

# §5b — golden-query benchmark reports. Reports include git_sha +
# timestamp in the filename and may be 100s of KB each; track them
# in an operations repo or as CI artifacts, not the source tree.
# Keep the directory so first-time runs don't error.
# Exception: pre-* baseline files are the comparison anchor — keep those.
src/fastapi/bench_results/*.json
!src/fastapi/bench_results/.gitkeep
bench_results/*.json
!bench_results/.gitkeep
!bench_results/*pre-*.json

# ADR-0008 — bge-small domain FT model files. 1.8 GB binary; lives at
# src/fastapi/models/ (bind-mounted as /app/models/ in both fastapi and
# hatchet-worker-ai containers). The canonical copy is persisted inside
# the container bind-mount; git is not the right place for model weights.
src/fastapi/models/

# §38/§39 reranker overnight — host-side artifacts that bind-mount or
# get stamped into the repo from docker exec calls. The real durable
# copies live in MinIO under `reranker-checkpoints/` / `reranker-labels/`.
# These rules just keep `git status` quiet on Kyle's working tree.
#
#   src/fastapi/data/      — older local mirror of reranker_dataset_v1
#                            (the same data lives in MinIO reranker-labels)
#   src/fastapi/scripts/   — Docker bind-mount echo of repo /scripts;
#                            edits belong in /scripts only.
#   tmp/                   — ad-hoc PHP/Python probe scripts left behind by
#                            older debugging sessions; not source files
#   bronze/                — textbook PDF dumps, belong in SeaweedFS/MinIO
#                            not git (GBs of binary corpus data)
src/fastapi/data/
src/fastapi/scripts/
/tmp/
/bronze/

# Claude Code agent scratch worktrees (never commit)
.claude/worktrees/
