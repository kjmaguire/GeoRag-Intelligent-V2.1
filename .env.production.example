# =============================================================================
# GeoRAG Intelligence V1.0 — Production Environment Variables
# =============================================================================
#
# This is the PRODUCTION template. All keys the stack reads are listed here
# with safe defaults or CHANGE_ME_VAULT_REFERENCE placeholders for secrets.
#
# Workflow:
#   1. Copy to .env.production (never commit the filled file)
#   2. Fill every CHANGE_ME_* placeholder using your secrets manager
#      (see ops/runbooks/secret-management.md for SOPS + age procedure)
#   3. Reference from docker-compose.yml via --env-file .env.production
#
# Secret format convention:
#   CHANGE_ME_VAULT_REFERENCE  — must be replaced; never leave as-is
#   CHANGE_ME_GENERATE_*       — generate with the command shown in the comment
#
# Differences from .env.example (dev defaults → production values):
#   APP_ENV=production
#   APP_DEBUG=false
#   LOG_LEVEL=info
#   SESSION_SECURE_COOKIE=true
#   TRUSTED_PROXIES=<real CIDR — not wildcard>
#   MULTI_TENANT_ENFORCEMENT_ENABLED=true
#   SINGLE_TENANT_MODE=false
#   All *_PASSWORD keys = CHANGE_ME_VAULT_REFERENCE
# =============================================================================


# =============================================================================
# APPLICATION — laravel-octane, laravel-horizon, laravel-reverb
# =============================================================================

APP_NAME="GeoRAG Intelligence"

# Must be "production". Changing this disables debug mode, sets cookie flags,
# and enables production-safe error handling throughout Laravel.
APP_ENV=production

# Generate: php artisan key:generate --show (run inside the container)
# Must be exactly 32 bytes, base64-encoded: base64:<value>
APP_KEY=CHANGE_ME_VAULT_REFERENCE

# Must be false in production. Exposing stack traces leaks internal paths.
APP_DEBUG=false

# Public HTTPS URL of the application. Used for redirects, asset URLs, email links.
APP_URL=https://your-georag-domain.example.com

# Host port for Laravel Octane. Default 80 (behind nginx/Traefik reverse proxy).
APP_PORT=80

# info is appropriate for production. Use warning to reduce I/O on busy hosts.
# Options: debug | info | warning | error | critical
LOG_LEVEL=info

# Octane worker settings. 8-core Ryzen workstation: 6 workers leaves 2 cores
# for the OS and other services. Tune to (cpu_cores - 2) for production hosts.
OCTANE_WORKERS=6
OCTANE_TASK_WORKERS=8
OCTANE_MAX_REQUESTS=500

# Swoole is the production server. RoadRunner is the alternative.
OCTANE_SERVER=swoole

# Reverse-proxy IP allowlist for X-Forwarded-* trust.
# Production: set to the explicit CIDR of your nginx/Traefik front-end.
# Do NOT use '*' in production — it allows clients to spoof X-Forwarded-For.
# Example: TRUSTED_PROXIES=10.0.0.0/8
TRUSTED_PROXIES=CHANGE_ME_YOUR_PROXY_CIDR

# Session cookie must be sent over HTTPS only.
SESSION_SECURE_COOKIE=true

# Comma-separated list of domains Laravel Sanctum allows stateful requests from.
# Must match the exact production domain (no wildcard).
SANCTUM_STATEFUL_DOMAINS=your-georag-domain.example.com

# CORS: which origins may call the API. Set to your exact frontend origin.
CORS_ALLOWED_ORIGINS=https://your-georag-domain.example.com

# Enforce multi-tenant workspace isolation (Module 9). Must be true in prod.
MULTI_TENANT_ENFORCEMENT_ENABLED=true
SINGLE_TENANT_MODE=false


# =============================================================================
# POSTGRESQL / POSTGIS — postgresql, pgbouncer, laravel-*, fastapi, dagster-*
#
# Applications connect via PgBouncer (port 6432), NOT PostgreSQL directly (5432).
# PostgreSQL port 5432 is NOT exposed to the host in production.
# =============================================================================

POSTGRES_DB=georag
POSTGRES_USER=georag
POSTGRES_PASSWORD=CHANGE_ME_VAULT_REFERENCE

# PgBouncer port exposed to host for direct psql inspection.
PGBOUNCER_PORT=6432

# PostgreSQL performance tuning (Section 06a) — NVMe workstation 64 GB RAM:
# shared_buffers: ~25% of system RAM
POSTGRES_SHARED_BUFFERS=16GB

# effective_cache_size: ~75% of system RAM
POSTGRES_EFFECTIVE_CACHE_SIZE=48GB

# work_mem: 256MB for production (128MB for dev). High values risk OOM if many
# simultaneous complex queries run. Monitor with pg_stat_statements.
POSTGRES_WORK_MEM=256MB

# CRITICAL: 1.1 for NVMe. Default 4.0 assumes spinning disks and will cause
# the planner to choose sequential scans over index scans. Never use 4.0 on NVMe.
POSTGRES_RANDOM_PAGE_COST=1.1

# Maximum direct connections to PostgreSQL (PgBouncer multiplexes these).
POSTGRES_MAX_CONNECTIONS=200

# Laravel framework wiring — connects through PgBouncer
DB_CONNECTION=pgsql
DB_HOST=pgbouncer
DB_PORT=6432
DB_DATABASE=georag
DB_USERNAME=georag
DB_PASSWORD=CHANGE_ME_VAULT_REFERENCE


# =============================================================================
# REDIS 8 — laravel-*, fastapi
#
# Used for: application cache, session storage, Horizon job queues.
# Production: 2GB maxmemory (workstation dev uses 512MB).
# =============================================================================

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_VAULT_REFERENCE

# Production memory budget: 2G. allkeys-lru evicts least-recently-used keys.
REDIS_MAXMEMORY=2gb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# AOF persistence for Horizon queue durability (max ~1s data loss on crash).
REDIS_APPENDONLY=yes
REDIS_APPENDFSYNC=everysec

# Laravel framework wiring
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=reverb

# Max concurrent LLM streaming Horizon workers. Each holds one SSE connection
# for the full query duration. Tune to FastAPI concurrency slots.
HORIZON_LLM_MAX_PROCESSES=4


# =============================================================================
# NEO4J COMMUNITY EDITION 2026 — neo4j, neo4j-warmup, fastapi, dagster-*
#
# Community Edition: no clustering, no Enterprise warmup, no database RBAC.
# Manual warmup via neo4j-warmup init container on stack boot.
# =============================================================================

NEO4J_HOST=neo4j
NEO4J_HTTP_PORT=7474
NEO4J_PORT=7687
NEO4J_BOLT_PORT=7687
NEO4J_URI=bolt://neo4j:7687

# Username is conventionally "neo4j". Password MUST be set before first start.
# Generate: openssl rand -hex 32
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=CHANGE_ME_VAULT_REFERENCE

# Memory tuning — Community Edition (Section 06b)
# Page cache: data on disk cached in RAM. 4G for 64GB workstation.
NEO4J_PAGECACHE_SIZE=4G

# JVM heap: 2G initial / 4G max. Do not exceed available RAM after other services.
NEO4J_HEAP_INITIAL_SIZE=2G
NEO4J_HEAP_MAX_SIZE=4G

# Database name to back up via neo4j-backup.md runbook.
NEO4J_DB_NAME=neo4j


# =============================================================================
# QDRANT v1.17 — qdrant, fastapi, dagster-*
#
# HNSW m=16, ef_construct=200 are set at service level.
# Per-collection indices and scalar quantization are applied by FastAPI on
# collection creation.
# =============================================================================

QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://qdrant:6333

# Production: set a strong API key. Dev can leave empty (network isolation only).
# QDRANT__SERVICE__API_KEY must also be set in the qdrant service environment.
QDRANT_API_KEY=CHANGE_ME_VAULT_REFERENCE

# HNSW index parameters — do not reduce below these values in production.
QDRANT_HNSW_M=16
QDRANT_HNSW_EF_CONSTRUCT=200
QDRANT_HNSW_EF=128


# =============================================================================
# SEAWEEDFS / MINIO-COMPATIBLE OBJECT STORAGE — minio, minio-init, laravel-*, dagster-*
#
# Bronze layer: immutable raw file archive. Variable names keep MINIO_ prefix
# for backward compat (ADR-0001: SeaweedFS replaces MinIO).
# API port: 8333 | Filer/admin: 8888
# Buckets: georag-bronze (raw files), georag-exports (user exports),
#          georag-bronze-raster (raster data)
# =============================================================================

MINIO_ROOT_USER=georag-admin
MINIO_ROOT_PASSWORD=CHANGE_ME_VAULT_REFERENCE

MINIO_API_PORT=8333
MINIO_CONSOLE_PORT=8888
MINIO_ENDPOINT=http://minio:8333

MINIO_BUCKET_BRONZE=bronze
MINIO_BUCKET_EXPORTS=exports
MINIO_BUCKET_BRONZE_RASTER=bronze-raster

# S3-compatible endpoint for backup uploads (same as MINIO_ENDPOINT).
S3_ENDPOINT_URL=http://minio:8333

# AWS CLI credentials for backup uploads to SeaweedFS.
# Match MINIO_ROOT_USER / MINIO_ROOT_PASSWORD values above.
AWS_ACCESS_KEY_ID=CHANGE_ME_VAULT_REFERENCE
AWS_SECRET_ACCESS_KEY=CHANGE_ME_VAULT_REFERENCE

# Backup retention: days before old backups are purged from S3.
BACKUP_RETENTION_DAYS=30

# Neo4j backup container name (used by backup scripts)
NEO4J_BACKUP_CONTAINER=georag-neo4j


# =============================================================================
# FASTAPI — fastapi, laravel-octane, laravel-horizon
#
# Service-to-service auth: Laravel sends JWT signed with FASTAPI_SERVICE_KEY.
# FastAPI verifies with the identical secret. Must be >= 32 bytes.
# =============================================================================

FASTAPI_HOST=fastapi
FASTAPI_PORT=8000

# Generate: python3 -c 'import secrets; print(secrets.token_urlsafe(48))'
# BOTH Laravel and FastAPI must hold the identical value.
FASTAPI_SERVICE_KEY=CHANGE_ME_VAULT_REFERENCE

# V1.5-03 — `kid` (key id) header on every minted JWT. The kid identifies
# which signing key minted the token; FastAPI maps kid → secret to support
# zero-downtime rotation. Standard initial value:
FASTAPI_SERVICE_KEY_KID=primary

# V1.5-03 — rotation overlap window. During key rotation, set both keys
# (PREVIOUS = outgoing kid+secret pair) so FastAPI accepts BOTH for ~1h
# while Laravel cuts over to the new mint kid. Empty in steady state.
# Documented in ops/runbooks/secret-rotation.md § FASTAPI_SERVICE_KEY.
# FASTAPI_SERVICE_KEY_PREVIOUS_KID=
# FASTAPI_SERVICE_KEY_PREVIOUS=


# =============================================================================
# CROSS-DATABASE TIMEOUTS (Section 06e) — fastapi
#
# These cap individual database calls. asyncio.gather collects all with an
# overall deadline of TIMEOUT_GATHER_S. Partial results are returned rather
# than failing the entire request on a single slow store.
# =============================================================================

TIMEOUT_POSTGIS_S=5
TIMEOUT_NEO4J_S=3
TIMEOUT_QDRANT_S=2
TIMEOUT_REDIS_MS=500

# Overall asyncio.gather deadline (seconds). 180s accommodates four §04i guards
# on the dev GPU. Prod GPU with higher TPS can use 120 or 90.
TIMEOUT_GATHER_S=180


# =============================================================================
# LLM CONFIGURATION — fastapi
#
# Backends:
#   vllm       — primary in dev + prod. OpenAI-compatible, prefix-cached.
#   anthropic  — optional cross-backend fallback (independent failure domain
#                from local GPU).
#
# Production recommendation: vllm primary, anthropic fallback. Concrete
# model + quant for prod is set in the production-readiness doc and
# tracked in docs/model_migration.md.
# =============================================================================

# Options: vllm | anthropic
LLM_BACKEND=vllm

# Fallback on primary failure: downshift | local_llm | off
LLM_BACKEND_FALLBACK=downshift

# Primary backend URL (vLLM in production). Model resolved via VLLM_MODEL below
# when LLM_BACKEND=vllm.
LLM_PRIMARY_URL=http://vllm:8000/v1
LLM_PRIMARY_MODEL=Qwen/Qwen3-14B-AWQ

# Anthropic fallback (optional — leave empty if not using)
ANTHROPIC_API_KEY=CHANGE_ME_VAULT_REFERENCE
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_MAX_OUTPUT_TOKENS=4096
ANTHROPIC_ENABLE_PROMPT_CACHING=true
ANTHROPIC_USE_PRIORITY_TIER=false

# Model tier aliases for FastAPI orchestrator
MODEL_TIER_FAST=claude-haiku-4-5
MODEL_TIER_STANDARD=claude-sonnet-4-6
MODEL_TIER_DEEP=claude-opus-4-8

# Legacy OpenAI-compatible fallback (leave empty unless needed)
LLM_FALLBACK_URL=
LLM_FALLBACK_ENABLED=false
LLM_FALLBACK_API_KEY=

# Context budget (tokens per category). Raise significantly when using Anthropic
# (Opus 4.7 1M context). Defaults here fit the vLLM Qwen3-14B-AWQ-AWQ profile
# at max-model-len=8192 (dev workstation A4500). Prod hardware with a larger
# context window can raise these — see ops/baselines/capacity-planning.md.
MAX_CONTEXT_TOKENS=6000
MAX_CONTEXT_COLLARS=20
MAX_CONTEXT_DOC_CHUNKS=5
MAX_CONTEXT_GRAPH_ENTITIES=20
MAX_CONTEXT_PG_RECORDS=12
MAX_VALIDATION_RETRIES=2

# RAG retrieval quality gate: reject below this score rather than prompting LLM
# with low-quality context. Matches Section 04i hallucination prevention.
RETRIEVAL_QUALITY_THRESHOLD=0.6

# Citation span resolver — must be true in production
CITATION_SPAN_RESOLVER_ENABLED=true

# Qwen thinking mode — set per-deployment based on model chosen
ENABLE_THINKING=false


# =============================================================================
# vLLM — vllm, fastapi
# Profile: gpu-llm. Qwen3-14B-AWQ on dev (A4500 20 GB); prod model and
# hardware tier set by the production-readiness doc.
#
# Larger GPUs unlock higher quality:
#   - L40S 48 GB / A100 80 GB → BF16 Qwen3-14B-AWQ (no quant), ~32K ctx.
#   - H100 80 GB              → FP8 Qwen3-14B-AWQ native (Hopper SM 9.0).
#   - Multi-GPU               → tensor-parallel, raise VLLM_TENSOR_PARALLEL.
# =============================================================================

VLLM_PORT=8001
VLLM_URL=http://vllm:8000/v1
VLLM_MODEL=Qwen/Qwen3-14B-AWQ
VLLM_SERVED_MODEL_NAME=Qwen/Qwen3-14B-AWQ
VLLM_QUANTIZATION=awq_marlin
VLLM_MAX_MODEL_LEN=8192
VLLM_GPU_MEM_UTIL=0.92
VLLM_TENSOR_PARALLEL=1
VLLM_GPU_COUNT=1

# HuggingFace token. Qwen3 AWQ is currently public; set this anyway so
# forward-compat swaps to gated repos (Llama, Mistral) don't break the deploy.
HF_TOKEN=CHANGE_ME_VAULT_REFERENCE


# =============================================================================
# LARAVEL REVERB — WebSocket server
# React clients connect to Reverb for real-time LLM token streaming.
# =============================================================================

REVERB_APP_ID=georag-app
# Generate: openssl rand -base64 32
REVERB_APP_KEY=CHANGE_ME_VAULT_REFERENCE
REVERB_APP_SECRET=CHANGE_ME_VAULT_REFERENCE

REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_HOST_PORT=8080
# Production: use wss (TLS-terminated by nginx/Traefik in front of Reverb)
REVERB_SCHEME=https

# Frontend Vite variables — must match Reverb settings above
VITE_REVERB_APP_KEY=CHANGE_ME_VAULT_REFERENCE
VITE_REVERB_HOST=your-georag-domain.example.com
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=wss

# V1.5-12 — Map base layers (DEM + satellite). On-prem deployments MUST set
# both to self-hosted endpoints (no external CDN dependency). The empty
# default falls back to public CDN — acceptable for connected deployments
# but a privacy/availability concern for air-gapped sites.
# Procedure: ops/runbooks/dem-self-host.md.
VITE_DEM_TILES_URL=https://tiles.your-georag-domain.example.com/dem/tilejson.json
VITE_SATELLITE_TILES_URL=https://tiles.your-georag-domain.example.com/sat/{z}/{y}/{x}.jpg


# =============================================================================
# MARTIN — PostGIS vector tile server
# Profile: dev-light. Serves geological vector layers as MVT tiles.
# =============================================================================

MARTIN_PORT=3002


# =============================================================================
# DAGSTER — dagster-daemon, dagster-webserver
# Profile: dev-ingest. Both services MUST run — daemon + webserver are separate.
# =============================================================================

DAGSTER_HOME=/opt/dagster/dagster_home
DAGSTER_WEBSERVER_PORT=3001

# Dagster uses its own PostgreSQL schema for run history and event log.
# Uses PgBouncer in production for connection pool management.
DAGSTER_PG_HOST=pgbouncer
DAGSTER_PG_PORT=6432
DAGSTER_PG_DB=georag_dagster
DAGSTER_PG_USER=georag
DAGSTER_PG_PASSWORD=CHANGE_ME_VAULT_REFERENCE


# =============================================================================
# RAGFLOW — document parsing and chunking
# Profile: dev-ingest. Start only during document ingestion work.
# Requires MySQL + ES + Redis sidecars — see ops/memory/project_ragflow_deferred.md
# =============================================================================

RAGFLOW_PORT=9380


# =============================================================================
# PROMETHEUS — metrics collection
# Profile: dev-monitor.
# =============================================================================

PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=30d


# =============================================================================
# ALERTMANAGER — alert routing
# Profile: dev-monitor. Routes alerts from Prometheus to Slack/PagerDuty/email.
# Configure receivers in docker/alertmanager/alertmanager.yml.
# =============================================================================

ALERTMANAGER_PORT=9093


# =============================================================================
# LOKI — log aggregation
# Profile: dev-monitor. Receives logs from Promtail; queried by Grafana LogQL.
# =============================================================================

LOKI_PORT=3100


# =============================================================================
# PROMETHEUS EXPORTERS — database metrics bridges
# Profile: dev-monitor. Expose native database metrics in Prometheus format.
#   redis_exporter    — oliver006/redis_exporter, MIT license
#   postgres_exporter — prometheuscommunity/postgres-exporter, Apache-2.0
#   neo4j_exporter    — georag/neo4j-exporter (local build), JMX→Prometheus sidecar
# =============================================================================

REDIS_EXPORTER_PORT=9121
POSTGRES_EXPORTER_PORT=9187
NEO4J_EXPORTER_PORT=9105


# =============================================================================
# GRAFANA — dashboards
# Profile: dev-monitor. Access at https://<host>:3000
# =============================================================================

GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_VAULT_REFERENCE
GRAFANA_ROOT_URL=https://your-georag-domain.example.com:3000


# =============================================================================
# LARAVEL FILESYSTEM / MAIL (framework wiring)
# =============================================================================

FILESYSTEM_DISK=s3
MAIL_MAILER=smtp


# =============================================================================
# HATCHET ENGINE — production hardening (added 2026-06-23 sweep)
# These three flags MUST be flipped from their dev defaults ("t") before
# any public exposure. The dev compose default is "t" for local-loop
# convenience; production gets the secure values via this file. The
# operator preflight (scripts/operator/preflight.sh) should assert all
# three are "f" before cd.yml is allowed to deploy.
# =============================================================================

# Send Set-Cookie with Secure flag (requires HTTPS termination upstream).
HATCHET_AUTH_COOKIE_INSECURE=f

# Reject plaintext gRPC; require TLS to hatchet-lite:7077. Pair with
# HATCHET_CLIENT_TLS_STRATEGY=tls (or mtls) on the worker side.
HATCHET_GRPC_INSECURE=f

# Stop auto-marking new accounts as email-verified — make signup go
# through the proper verification flow.
HATCHET_AUTH_SET_EMAIL_VERIFIED=f
