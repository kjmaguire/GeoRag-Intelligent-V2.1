{
  "annotations": {"list": []},
  "description": "Phase 2 Step 7 — Activepieces-driven Hatchet workflow run observability. Reads v1_runs_olap from the hatchet DB via the grafana_hatchet_readonly role; filters to the workflow names registered in FastAPI's FLOW_REGISTRY.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {"type": "postgres", "uid": "PostgreSQL-Hatchet"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.95},
              {"color": "green", "value": 0.99}
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "Success rate (24h)",
      "type": "gauge",
      "targets": [
        {
          "datasource": {"type": "postgres", "uid": "PostgreSQL-Hatchet"},
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT CASE WHEN total = 0 THEN NULL ELSE completed::float / total END AS value FROM (SELECT count(*) FILTER (WHERE r.readable_status = 'COMPLETED') AS completed, count(*) FILTER (WHERE r.readable_status IN ('COMPLETED','FAILED','CANCELLED','EVICTED')) AS total FROM v1_runs_olap r JOIN \"WorkflowVersion\" v ON v.id = r.workflow_version_id JOIN \"Workflow\" w ON w.id = v.\"workflowId\" WHERE w.name IN ('public_geoscience_pull','external_notification','phase2_smoke') AND r.inserted_at > now() - interval '24 hours') sub"
        }
      ]
    },
    {
      "datasource": {"type": "postgres", "uid": "PostgreSQL-Hatchet"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "bars", "lineWidth": 1, "fillOpacity": 60, "stacking": {"mode": "normal"}},
          "mappings": [],
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 9, "w": 18, "x": 6, "y": 0},
      "id": 2,
      "options": {
        "legend": {"showLegend": true, "displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "none"}
      },
      "title": "Workflow runs by status (1h buckets)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "postgres", "uid": "PostgreSQL-Hatchet"},
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('hour', r.inserted_at) AS time, w.name || ' / ' || r.readable_status::text AS metric, count(*)::int AS value FROM v1_runs_olap r JOIN \"WorkflowVersion\" v ON v.id = r.workflow_version_id JOIN \"Workflow\" w ON w.id = v.\"workflowId\" WHERE w.name IN ('public_geoscience_pull','external_notification','phase2_smoke') AND r.inserted_at > now() - interval '24 hours' GROUP BY 1, 2 ORDER BY 1"
        }
      ]
    },
    {
      "datasource": {"type": "postgres", "uid": "PostgreSQL-Hatchet"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 5},
      "id": 3,
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto"
      },
      "title": "Total runs (24h)",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "postgres", "uid": "PostgreSQL-Hatchet"},
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT count(*)::int AS value FROM v1_runs_olap r JOIN \"WorkflowVersion\" v ON v.id = r.workflow_version_id JOIN \"Workflow\" w ON w.id = v.\"workflowId\" WHERE w.name IN ('public_geoscience_pull','external_notification','phase2_smoke') AND r.inserted_at > now() - interval '24 hours'"
        }
      ]
    },
    {
      "datasource": {"type": "postgres", "uid": "PostgreSQL-Hatchet"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "align": "left",
            "displayMode": "auto",
            "filterable": true
          },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "status"},
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "mappings",
                "value": [
                  {"type": "value", "options": {"COMPLETED": {"color": "green", "index": 0}}},
                  {"type": "value", "options": {"FAILED": {"color": "red", "index": 1}}},
                  {"type": "value", "options": {"RUNNING": {"color": "blue", "index": 2}}},
                  {"type": "value", "options": {"QUEUED": {"color": "yellow", "index": 3}}},
                  {"type": "value", "options": {"CANCELLED": {"color": "gray", "index": 4}}}
                ]
              }
            ]
          }
        ]
      },
      "gridPos": {"h": 11, "w": 24, "x": 0, "y": 9},
      "id": 4,
      "options": {
        "showHeader": true,
        "footer": {"show": false}
      },
      "title": "Recent runs (last 100)",
      "type": "table",
      "targets": [
        {
          "datasource": {"type": "postgres", "uid": "PostgreSQL-Hatchet"},
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT r.inserted_at AS time, w.name AS flow_name, r.readable_status::text AS status, r.external_id::text AS run_id FROM v1_runs_olap r JOIN \"WorkflowVersion\" v ON v.id = r.workflow_version_id JOIN \"Workflow\" w ON w.id = v.\"workflowId\" WHERE w.name IN ('public_geoscience_pull','external_notification','phase2_smoke') ORDER BY r.inserted_at DESC LIMIT 100"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["georag", "phase2", "activepieces", "integrations"],
  "templating": {"list": []},
  "time": {"from": "now-24h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "GeoRAG / Integrations",
  "uid": "georag-integrations",
  "version": 1,
  "weekStart": ""
}
