{
  "annotations": {"list": []},
  "description": "§16.1 product-tier — ingestion throughput per workspace: bytes/sec, format mix, OCR fallback rate, PDF preflight verdicts.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"unit": "decbytes"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "title": "Bronze Bytes Ingested (1h, by format)",
      "type": "timeseries",
      "targets": [
        {"expr": "sum by (format) (rate(georag_bronze_bytes_total{workspace_id=~\"$workspace\"}[1h]))"}
      ]
    },
    {
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "title": "PDF Preflight Verdicts (24h)",
      "type": "piechart",
      "targets": [
        {"expr": "sum by (verdict) (increase(georag_pdf_preflight_total{workspace_id=~\"$workspace\"}[24h]))"}
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "title": "OCR Fallback Rate (24h)",
      "type": "gauge",
      "targets": [
        {"expr": "sum (rate(georag_pdf_ocr_fallback_total{workspace_id=~\"$workspace\"}[24h])) / sum (rate(georag_pdf_processed_total{workspace_id=~\"$workspace\"}[24h]))"}
      ]
    },
    {
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 4,
      "title": "Silver → Gold Lag (sec)",
      "type": "timeseries",
      "targets": [
        {"expr": "max by (workspace_id) (georag_dagster_materialise_lag_seconds{workspace_id=~\"$workspace\"})"}
      ]
    },
    {
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "id": 5,
      "title": "Chunks per Document (P50 / P95)",
      "type": "timeseries",
      "targets": [
        {"expr": "histogram_quantile(0.5, sum by (le, workspace_id) (rate(georag_chunks_per_doc_bucket{workspace_id=~\"$workspace\"}[1h])))",
         "legendFormat": "p50 {{workspace_id}}"},
        {"expr": "histogram_quantile(0.95, sum by (le, workspace_id) (rate(georag_chunks_per_doc_bucket{workspace_id=~\"$workspace\"}[1h])))",
         "legendFormat": "p95 {{workspace_id}}"}
      ]
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["georag", "product", "ingestion"],
  "templating": {
    "list": [
      {"name": "workspace", "type": "query", "datasource": "Prometheus",
       "query": "label_values(georag_bronze_bytes_total, workspace_id)",
       "includeAll": true, "multi": true}
    ]
  },
  "time": {"from": "now-24h", "to": "now"},
  "timezone": "browser",
  "title": "GeoRAG / Product / Ingestion Throughput",
  "uid": "georag-product-ingestion-throughput",
  "version": 1
}
