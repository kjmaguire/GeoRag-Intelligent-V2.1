  "panels": [
    {
      "type": "timeseries",
      "title": "Horizon queue depth by queue",
      "description": "Pending jobs per queue. Sustained growth = consumer slowdown.",
      "targets": [{"expr": "horizon_queue_depth", "refId": "A", "legendFormat": "{{queue}}"}],
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1000}, {"color": "red", "value": 10000}]}}},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1
    },
    {
      "type": "timeseries",
      "title": "Octane worker saturation (busy / total)",
      "description": "Octane request-in-flight ratio. > 85% sustained = throttle latency.",
      "targets": [{"expr": "octane_workers_busy / octane_workers_total", "refId": "A", "legendFormat": "saturation"}],
      "fieldConfig": {"defaults": {"unit": "percentunit", "max": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.7}, {"color": "red", "value": 0.85}]}}},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2
    },
    {
      "type": "timeseries",
      "title": "Pulse exceptions / 5m by class",
      "description": "Pulse-aggregated exception classes. Rate spike = regression or attack.",
      "targets": [{"expr": "sum by (class) (rate(pulse_exception_total[5m]))", "refId": "A", "legendFormat": "{{class}}"}],
      "fieldConfig": {"defaults": {"unit": "short"}},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3
    },
    {
      "type": "timeseries",
      "title": "Slow queries / 5m by connection",
      "description": "Pulse slow-query log rolled up by DB connection. Correlate spikes with PostgreSQL dashboard's lock-contention panel.",
      "targets": [{"expr": "sum by (connection) (rate(slow_queries_total[5m]))", "refId": "A", "legendFormat": "{{connection}}"}],
      "fieldConfig": {"defaults": {"unit": "short"}},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 4
    },
    {
      "type": "timeseries",
      "title": "Cache hit ratio per store",
      "description": "Pulse cache hit:miss aggregates (5m window). < 0.8 = cache thrash or insufficient size.",
      "targets": [{"expr": "cache_hit_ratio", "refId": "A", "legendFormat": "{{store}}"}],
      "fieldConfig": {"defaults": {"unit": "percentunit", "max": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.7}, {"color": "green", "value": 0.85}]}}},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "id": 5
    },
    {
      "type": "stat",
      "title": "Octane workers total",
      "description": "Configured worker pool size — must scale with traffic.",
      "targets": [{"expr": "octane_workers_total", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 16},
      "id": 6
    },
    {
      "type": "stat",
      "title": "Octane workers busy (now)",
