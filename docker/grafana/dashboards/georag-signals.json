{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Signal-harvesting board — classifier escalation, prompt cache hit rate, model routing, retrieval quality. Tracks the 'measure before building' discipline signals from Phases 2/3/4.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "Classifier escalation (R9 signal)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Count of queries where the keyword classifier fell through AND every tool returned empty. This is the primary trigger for deciding whether to invest in a full Pydantic AI agent path (R9-full).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum(rate(georag_escalation_triggered_total[30m])) / clamp_min(sum(rate(georag_queries_total[30m])), 0.001)",
          "legendFormat": "escalation rate",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Escalation rate (30m)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "When an escalation fired, what fraction of rephrasings rescued the query (produced non-empty results)? If this stays > 0.5, the bounded escalation is earning its keep. Drops below 0.2 → R9-full is due.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "green", "value": 0.5 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum(rate(georag_escalation_outcome_total{outcome=\"success\"}[1h])) / clamp_min(sum(rate(georag_escalation_outcome_total[1h])), 0.001)",
          "legendFormat": "success rate",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Escalation success rate (1h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "How many alternative phrasings the LLM proposed per escalation. Low averages (< 1.5) suggest the rephrasing prompt isn't getting the variety it should.",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["mean"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum(rate(georag_escalation_rephrasings_total[1h])) / clamp_min(sum(rate(georag_escalation_triggered_total[1h])), 0.001)",
          "legendFormat": "avg rephrasings per escalation",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Avg rephrasings per escalation (1h)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "panels": [],
      "title": "Prompt cache hit rate (C6 + R15)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Input tokens the backend served from cache, divided by total input tokens. Anthropic ephemeral cache + vLLM prefix cache both report this the same way.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineInterpolation": "smooth", "fillOpacity": 10 },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
      "id": 4,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum by (backend) (rate(georag_prompt_cache_input_tokens_total[5m])) / clamp_min(sum by (backend) (rate(georag_prompt_input_tokens_total[5m])), 0.001)",
          "legendFormat": "{{backend}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Cache hit rate over time (per backend)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "panels": [],
      "title": "Model routing + failover (B1)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Queries routed to each tier. A healthy deployment should have most queries on FAST/STANDARD; DEEP should be the exception (retries + complex queries).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 5,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum by (tier) (rate(georag_routing_decisions_total[5m]))",
          "legendFormat": "{{tier}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Routing decisions per second by tier",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Failover events — Anthropic 429/529/timeout → downshift or DeepSeek. Sustained > 0.01 rps suggests Anthropic capacity pressure or a rate-limit tier problem.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 6,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum by (from_tier, exception_class) (rate(georag_llm_failovers_total[5m]))",
          "legendFormat": "{{from_tier}} / {{exception_class}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Failovers per second",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 104,
      "panels": [],
      "title": "Cost accountability (USD)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "LLM spend rate in USD/hour, broken down by model. Opus spikes against a rate-limited Max plan usually mean the classifier is over-escalating to DEEP tier — cross-check with the routing panel.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "currencyUSD"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "id": 9,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "sum by (model) (rate(georag_llm_cost_usd_total[5m])) * 3600",
          "legendFormat": "{{model}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "USD/hour by model",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Top user buckets by spend over the last hour. Bucket IDs are deterministic SHA-256-first-hex of user_id; drill down via Loki logs if a bucket looks hot.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "currencyUSD"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "id": 10,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "topk(5, sum by (user_bucket) (increase(georag_llm_cost_usd_total[1h])))",
          "legendFormat": "{{user_bucket}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Top user buckets — USD in last hour",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "id": 103,
      "panels": [],
      "title": "Retrieval quality + latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Distribution of chunks returned to the LLM after reranking + quality gate. A mode at 0 means queries are starving; mode at RERANKER_TOP_K (5) means the pipeline is producing full context.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 37 },
      "id": 7,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.5, sum(rate(georag_retrieval_chunks_returned_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum(rate(georag_retrieval_chunks_returned_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Chunks returned per query (p50 / p95)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "End-to-end orchestrator latency. A widening gap between p50 and p95 usually means a small fraction of queries are hitting retries or escalation.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 37 },
      "id": 8,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.5, sum(rate(georag_query_duration_seconds_bucket{outcome=\"completed\"}[5m])) by (le))",
          "legendFormat": "p50",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum(rate(georag_query_duration_seconds_bucket{outcome=\"completed\"}[5m])) by (le))",
          "legendFormat": "p95",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Query duration — completed (p50 / p95)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["georag", "rag", "signals"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
