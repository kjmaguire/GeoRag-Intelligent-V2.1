# Normalize line endings on commit. Without this, a Windows checkout converts
# .php files to CRLF, and `vendor/bin/pint --test` reports every file as
# needing the `line_ending` fixer.
#
# `text=auto` lets Git detect text files and normalize them to LF in the repo.
# Specific extensions below are pinned to LF to avoid surprises.
* text=auto eol=lf

# PHP and config files are always LF.
*.php       text eol=lf
*.json      text eol=lf
*.xml       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.neon      text eol=lf
*.env       text eol=lf
*.example   text eol=lf
*.md        text eol=lf

# JS/TS/CSS — also LF for tooling consistency (Prettier, ESLint, Vite, Tailwind).
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.html      text eol=lf
*.vue       text eol=lf

# Shell scripts must be LF or they break on Linux containers.
*.sh        text eol=lf
*.bash      text eol=lf

# SQL / Cypher.
*.sql       text eol=lf
*.cypher    text eol=lf

# Python — LF on Windows too; matches the FastAPI service's Linux deployment.
*.py        text eol=lf

# Windows batch files — keep CRLF.
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binary files — never normalize.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.tar.gz    binary
*.gz        binary
*.tgz       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.otf       binary

# Files excluded from the GitHub language stats (linguist).
georag-architecture.html linguist-documentation
docs/**     linguist-documentation
